{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixpkgs": ["pkgs.nodejs_22"]
        },
        "install": {
          "cmds": ["npm install"]
        },
        "build": {
          "cmds": ["npx tsc server/listening_server.ts --outDir server/dist --module ESNext --moduleResolution node --target ES2020 --esModuleInterop true --skipLibCheck"]
        }
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthCheckPath": "/api/listening/health"
  }
}
