# ============================================================
# VinaListen Backend — Environment Variables Template
# ============================================================

APP_NAME=VinaListen
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# PostgreSQL (Supabase)
DB_CONNECTION=pgsql
DB_HOST=your-supabase-pooler-host.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres.your-connection-string
DB_PASSWORD=

# Session & Cache
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# Cloudflare R2 (S3-compatible)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_ENDPOINT=https://xxx.r2.cloudflarestorage.com
AWS_BUCKET=vinalisten-audio
AWS_USE_PATH_STYLE_ENDPOINT=true
R2_PUBLIC_URL=https://audio.vinalisten.app

# CORS — comma-separated origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://vinalisten.app

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:3000,vinalisten.app

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback

LOG_CHANNEL=stack
LOG_LEVEL=debug

MAIL_MAILER=log
