# ============================================================
# VinaListen — Environment Variables Template
# ============================================================

# --- Frontend API ---
VITE_API_URL=
VITE_LISTENING_API_URL=

# --- Listening Server (Railway) ---
DB_HOST=
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=
DB_PASSWORD=
DB_SSL=true
LISTENING_PORT=3002

# --- Database (PostgreSQL via Supabase) ---
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# --- Cloudflare R2 (Audio Storage) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=vinalisten-audio
R2_ACCOUNT_ID=
R2_PUBLIC_URL=

# --- App ---
APP_NAME=VinaListen
APP_URL=http://localhost:3000
APP_ENV=local
APP_DEBUG=true
APP_KEY=

# --- Session ---
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://vinalisten.app

# --- Sanctum ---
SANCTUM_STATEFUL_DOMAINS=localhost:3000,vinalisten.app
