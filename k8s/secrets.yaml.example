# ============================================================
# Kubernetes — Secrets Template
# Copy to staging/secrets.yaml and production/secrets.yaml
# DO NOT commit actual secrets to version control
# ============================================================

apiVersion: v1
kind: Secret
metadata:
  name: backend-secrets
  namespace: drivesmart
type: Opaque
stringData:
  database-url: postgresql://user:password@postgres:5432/drivesmart
  gemini-api-key: your-gemini-api-key
  redis-url: redis://redis:6379
---
apiVersion: v1
kind: Secret
metadata:
  name: frontend-config
  namespace: drivesmart
type: Opaque
stringData:
  vite-api-url: https://api-staging.drivesmart.app
